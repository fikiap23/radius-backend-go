# =============================================================================
# Development — copy to build/.env
#   cd build && cp .env.example .env
# =============================================================================

RADIUS_APP_ENV=development
RADIUS_APP_LOGLEVEL=debug

HTTP_PORT=8080
RADIUS_HTTP_PORT=8080
RADIUS_HTTP_READTIMEOUT=15s
RADIUS_HTTP_WRITETIMEOUT=15s
RADIUS_HTTP_SHUTDOWNTIMEOUT=30s

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=radius
DB_PORT=5432

RADIUS_DATABASE_HOST=postgres
RADIUS_DATABASE_PORT=5432
RADIUS_DATABASE_USER=postgres
RADIUS_DATABASE_PASSWORD=postgres
RADIUS_DATABASE_NAME=radius
RADIUS_DATABASE_SSLMODE=disable
RADIUS_DATABASE_MAXOPENCONNS=25
RADIUS_DATABASE_MAXIDLECONNS=10
RADIUS_DATABASE_CONNMAXLIFETIME=5m

RADIUS_JWT_SECRETKEY=dev-secret-change-me-please-32chars
RADIUS_JWT_ISSUER=radius-backend
# Supports Go durations (24h, 30m) or day suffix (7d).
RADIUS_JWT_EXPIRY=7d

# SSO OAuth (optional — leave empty to disable provider)
RADIUS_OAUTH_STATEEXPIRY=10m
# Comma-separated allowlist; empty = any http(s) redirect_uri allowed
RADIUS_OAUTH_ALLOWEDREDIRECTURIS=http://localhost:3000/auth/callback/google,http://localhost:3000/auth/callback/github
RADIUS_OAUTH_GOOGLE_CLIENTID=
RADIUS_OAUTH_GOOGLE_CLIENTSECRET=
RADIUS_OAUTH_GITHUB_CLIENTID=
RADIUS_OAUTH_GITHUB_CLIENTSECRET=
